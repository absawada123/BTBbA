{
  "name": "beyondthebloombya",
  "version": "1.0.0",
  "private": true,
  "description": "Beyond the Bloom by A",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd client && vite",
    "dev:backend": "npm run db:migrate && cd backend && nodemon src/server.js",
    "db:migrate": "node backend/src/database/migrate.js",
    "db:seed": "node backend/src/database/seed.js",
    "db:reset": "npm run db:seed",
    "build:frontend": "cd client && tsc -b && vite build",
    "build:backend": "cd backend && tsc -b",
    "start": "npm run dev:frontend & npm run dev:backend",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.7",
    "nodemon": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0"
  }
}
